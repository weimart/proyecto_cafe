{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Chrome",
      "type": "chrome",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/http-server",
      "runtimeArgs": [
        ".",
        "-p",
        "8000",
        "-o",
        "src/index.html"
      ],
      "url": "http://localhost:8000",
      "webRoot": "${workspaceFolder}",
      "sourceMapPathOverride": {
        "webpack:///./src/*": "${webRoot}/src/*"
      }
    }
  ]
}
